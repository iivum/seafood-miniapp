# ===========================================
# 海鲜商城小程序 - 环境变量配置模板
# ===========================================
# 复制此文件为 .env 后根据实际情况修改

# ============ 开发环境 ============
NODE_ENV=development
MINIPROGRAM_API_BASE_URL=http://localhost:8080

# ============ 生产环境 ============
# NODE_ENV=production
# MINIPROGRAM_API_BASE_URL=https://api.seafood-mall.com

# ============ MongoDB 配置 ============
MONGODB_URI=mongodb://localhost:27017/seafood

# 各服务独立的 MongoDB（可选）
# MONGODB_PRODUCT_URI=mongodb://localhost:27017/seafood_product
# MONGODB_ORDER_URI=mongodb://localhost:27017/seafood_order
# MONGODB_USER_URI=mongodb://localhost:27017/seafood_user

# ============ Eureka 服务发现 ============
EUREKA_URI=http://localhost:8761/eureka/

# ============ JWT 认证（待实现）============
# JWT_SECRET=your-secret-key-here
# JWT_EXPIRATION=86400

# ============ 微信支付配置（待实现）============
# WECHAT_APP_ID=your-app-id
# WECHAT_MCH_ID=your-merchant-id
# WECHAT_API_KEY=your-api-key
# WECHAT_NOTIFY_URL=https://api.seafood-mall.com/pay/notify

# ============ Docker 环境 ============
# COMPOSE_PROJECT_NAME=seafood
