{
  "name": "seafood-miniapp-frontend",
  "version": "1.0.0",
  "description": "Seafood E-commerce Mini Program Frontend",
  "author": "iivum",
  "repository": "https://github.com/iivum/seafood-miniapp",
  "license": "MIT",
  "main": "app.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js,.ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "seafood",
    "e-commerce",
    "mini-program"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "miniprogram-api-typings": "^5.1.2",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.2"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/__tests__/**/*.[jt]s?(x)",
      "**/?(*.)+(spec|test).[tj]s?(x)"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "html",
      "json"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 75,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "verbose": true,
    "testTimeout": 30000,
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "utils/request.js"
    ]
  },
  "dependencies": {
    "@vant/weapp": "^1.11.7"
  }
}
