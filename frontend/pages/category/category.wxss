.category-container {
  min-height: 100vh;
  background-color: var(--color-bg-subtle);
}

/* Category grid view */
.category-grid {
  padding: 20rpx;
}

.category-grid-inner {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.category-item {
  width: 31%;
  min-width: 180rpx;
  background-color: var(--color-surface);
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(30, 58, 95, 0.08);
  box-sizing: border-box;
}

.category-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  background-color: var(--color-bg-subtle);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.category-icon {
  font-size: 60rpx;
  line-height: 1;
}

.category-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.category-desc {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

/* Products view */
.products-view {
  padding: 0;
}

.category-header {
  background-color: var(--color-surface);
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid var(--color-border);
}

.category-header-left {
  display: flex;
  align-items: center;
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

.back-arrow {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.category-title {
  margin-left: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

/* Product list */
.product-list {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  justify-content: space-between;
}

.product-item {
  width: 48%;
  background-color: var(--color-surface);
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(30, 58, 95, 0.08);
}

.product-img {
  width: 100%;
  height: 340rpx;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 28rpx;
  color: var(--color-text);
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  font-size: 32rpx;
  color: var(--color-price);
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.add-cart-btn {
  background-color: var(--color-primary);
  color: #fff;
  font-size: 24rpx;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 8rpx;
}

/* Loading, error, empty states */
.loading-state,
.error-state,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-state text,
.empty-state text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.error-text,
.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 30rpx;
}

.retry-btn {
  background-color: var(--color-primary);
  color: #fff;
  font-size: 26rpx;
  padding: 16rpx 40rpx;
  border-radius: 8rpx;
}

.loading-more,
.no-more {
  text-align: center;
  padding: 30rpx;
  color: var(--color-text-muted);
  font-size: 24rpx;
}
