<view class="home-container">
  <!-- 搜索栏 - 适配异形屏 -->
  <view class="search-bar safe-area-top">
    <view class="search-input">
      <icon type="search" size="14"></icon>
      <input
        placeholder="搜索你心仪的海鲜"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
        confirm-type="search"
        focus="{{searchFocused}}"
      />
      <icon wx:if="{{searchKeyword}}" type="clear" size="14" bindtap="onClearSearch"></icon>
    </view>
  </view>

  <!-- 搜索结果提示 -->
  <view class="search-tip" wx:if="{{searchKeyword}}">
    <text>搜索: {{searchKeyword}}</text>
    <text class="clear-search" bindtap="onClearSearch">清除</text>
  </view>

  <!-- 热门搜索词 -->
  <view class="hot-search-section" wx:if="{{showHotSearch && !searchKeyword}}">
    <view class="hot-search-header">
      <text class="hot-search-title">🔥 热门搜索</text>
    </view>
    <view class="hot-search-list">
      <navigator
        class="hot-search-item"
        wx:for="{{hotSearchKeywords}}"
        wx:key="index"
        url="/pages/search/search?keyword={{item.keyword}}"
        open-type="navigate"
      >
        <text>{{item.keyword}}</text>
      </navigator>
    </view>
  </view>

  <!-- 轮播图 - 使用emoji替代缺失的图片 -->
  <swiper class="banner" indicator-dots="true" autoplay="true" interval="3000" duration="500">
    <swiper-item>
      <view class="banner-placeholder">
        <text class="banner-emoji">🦐</text>
        <text class="banner-text">新鲜虾蟹 限时优惠</text>
      </view>
    </swiper-item>
    <swiper-item>
      <view class="banner-placeholder">
        <text class="banner-emoji">🦞</text>
        <text class="banner-text">鲜活龙虾 产地直发</text>
      </view>
    </swiper-item>
  </swiper>

  <!-- 分类入口 -->
  <view class="category-nav safe-area-bottom-fixed">
    <view class="nav-item" wx:for="{{categories}}" wx:key="id" bindtap="onCategoryTap" data-category="{{item.id}}">
      <view class="category-icon-wrapper">
        <text class="category-icon">{{item.icon}}</text>
      </view>
      <text>{{item.name}}</text>
    </view>
  </view>

  <!-- 今日推荐 -->
  <view class="section-title">今日推荐</view>

  <!-- 加载中状态 -->
  <view class="loading-state" wx:if="{{isLoading && products.length === 0}}">
    <text>加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-state" wx:elif="{{isError}}">
    <text class="error-text">{{errorMessage}}</text>
    <view class="retry-btn" bindtap="onRetry">重新加载</view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{isEmpty}}">
    <text class="empty-text">{{emptyMessage}}</text>
    <view class="retry-btn" bindtap="onRetry">重新加载</view>
  </view>

  <!-- 商品列表 -->
  <view class="product-list" wx:else>
    <view class="product-item" wx:for="{{products}}" wx:key="id">
      <navigator class="product-navigator" url="/pages/detail/detail?id={{item.id}}" open-type="navigate">
        <image class="product-img" src="{{item.imageUrl}}" mode="aspectFill" lazy-load="true"></image>
        <view class="product-info">
          <view class="product-name">
            <text wx:if="{{!item.nameHighlighted}}">{{item.name}}</text>
            <view wx:else class="highlight-wrapper">
              <text>{{item.nameBefore}}</text><text class="highlight">{{item.nameMatch}}</text><text>{{item.nameAfter}}</text>
            </view>
          </view>
          <text class="product-price">￥{{item.price}}</text>
        </view>
      </navigator>
      <view class="add-cart-btn" catchtap="addToCart" data-product="{{item}}">加入购物车</view>
    </view>
  </view>

  <!-- 加载更多状态 -->
  <view class="loading-more" wx:if="{{isLoadingMore}}">
    <text>加载更多...</text>
  </view>

  <!-- 没有更多数据 -->
  <view class="no-more" wx:if="{{!hasMore && products.length > 0}}">
    <text>没有更多了</text>
  </view>
</view>
