.home-container {
  padding-bottom: 50rpx;
  background-color: var(--color-bg);
}

/* ============================================
   Search Bar
   ============================================ */
.search-bar {
  padding: 20rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background-color: var(--color-surface);
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid var(--color-divider);
}

.search-input {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: var(--color-bg-subtle);
  border-radius: 30rpx;
  padding: 10rpx 20rpx;
}

.search-btn {
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  background-color: var(--color-accent);
  color: #fff;
  font-size: 26rpx;
  border-radius: 30rpx;
  margin-left: 20rpx;
  border: none;
}

.search-tip {
  padding: 15rpx 20rpx;
  background-color: #fff8e6;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.clear-search {
  color: var(--color-accent);
  font-weight: 500;
}

/* ============================================
   Hot Search Section
   ============================================ */
.hot-search-section {
  background-color: var(--color-surface);
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.hot-search-header {
  margin-bottom: 20rpx;
}

.hot-search-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.hot-search-list {
  display: flex;
  flex-wrap: wrap;
  margin: -10rpx -10rpx;
}

.hot-search-item {
  padding: 10rpx 24rpx;
  background-color: var(--color-bg-subtle);
  border-radius: 30rpx;
  margin: 10rpx;
  border: 1rpx solid var(--color-border);
}

.hot-search-item text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* ============================================
   Banner Carousel
   ============================================ */
.banner {
  height: 300rpx;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(30, 58, 95, 0.12);
}

.banner image {
  width: 100%;
  height: 100%;
}

/* ============================================
   Category Navigation
   ============================================ */
.category-nav {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
  background-color: var(--color-surface);
  margin-bottom: 20rpx;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-item image {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 10rpx;
  border-radius: 50%;
  background-color: var(--color-bg-subtle);
}

.nav-item text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* ============================================
   Product Grid
   ============================================ */
.section-title {
  padding: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  background-color: var(--color-bg);
}

.product-list {
  display: flex;
  flex-wrap: wrap;
  padding: 10rpx;
  background-color: var(--color-bg);
}

.product-item {
  width: 50%;
  box-sizing: border-box;
  padding: 10rpx;
}

.product-img {
  width: 100%;
  height: 350rpx;
  border-radius: 12rpx;
  background-color: var(--color-bg-subtle);
}

.product-info {
  background-color: var(--color-surface);
  padding: 10rpx;
  border-radius: 0 0 12rpx 12rpx;
  border: 1rpx solid var(--color-border);
  border-top: none;
}

.product-name {
  font-size: 28rpx;
  display: block;
  color: var(--color-text);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.highlight-wrapper {
  display: inline;
}

.highlight {
  color: var(--color-price);
  font-weight: 600;
}

.product-price {
  font-size: 30rpx;
  color: var(--color-price);
  font-weight: 600;
  margin-top: 8rpx;
}

/* Add to Cart Button - Accent Coral */
.add-cart-btn {
  background-color: var(--color-accent);
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-top: 10rpx;
  text-align: center;
}
