/* 地址列表页面样式 */
.address-list-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 地址列表 */
.address-list {
  padding-bottom: 120rpx;
}

.address-item {
  margin-bottom: 20rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.address-item:active {
  transform: scale(0.98);
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.address-header .name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.address-header .phone {
  font-size: 28rpx;
  color: #666;
  flex: 1;
}

.address-header .default-tag {
  background: #ff5252;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.address-content {
  margin-bottom: 20rpx;
}

.address-content .address-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.address-actions {
  display: flex;
  justify-content: flex-end;
  gap: 40rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #666;
  font-size: 26rpx;
  transition: all 0.3s;
}

.action-item:active {
  color: #007aff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.empty-state icon {
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-state .empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-state .empty-subtext {
  font-size: 26rpx;
  color: #ccc;
}

/* 添加地址按钮 */
.add-address-btn {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
  height: 90rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s;
}

.add-address-btn:active {
  transform: scale(0.98);
  box-shadow: 0 5rpx 20rpx rgba(102, 126, 234, 0.3);
}

.add-address-btn icon {
  margin-right: 10rpx;
}

/* 选择模式样式 */
.address-item.select-mode {
  position: relative;
  padding-left: 80rpx;
}

.address-item.select-mode::before {
  content: '';
  position: absolute;
  left: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #ccc;
  border-radius: 50%;
  transition: all 0.3s;
}

.address-item.select-mode.selected::before {
  background: #667eea;
  border-color: #667eea;
}

.address-item.select-mode.selected::after {
  content: '✓';
  position: absolute;
  left: 36rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #fff;
  font-size: 24rpx;
}