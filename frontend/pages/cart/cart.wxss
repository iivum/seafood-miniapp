.cart-container {
  padding-bottom: 120rpx;
}

.cart-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  color: #999;
}

.cart-empty text {
  margin: 30rpx 0;
}

/* 地址选择区域 */
.address-section {
  margin-bottom: 20rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: all 0.3s;
}

.address-section:active {
  transform: scale(0.98);
}

.address-info .address-header {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.address-info .name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.address-info .phone {
  font-size: 28rpx;
  color: #666;
}

.address-info .address-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.address-empty {
  display: flex;
  align-items: center;
  color: #999;
}

.address-empty icon {
  margin-right: 10rpx;
}

.arrow-icon {
  color: #999;
}

/* 全选栏 */
.select-all-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.select-all {
  display: flex;
  align-items: center;
}

.select-all text {
  margin-left: 10rpx;
  font-size: 28rpx;
  color: #333;
}

.selected-info {
  font-size: 26rpx;
  color: #666;
}

/* 优惠券区域 */
.coupon-section {
  margin-bottom: 20rpx;
  padding: 20rpx 30rpx;
}

.coupon-input-row {
  display: flex;
  align-items: center;
}

.coupon-input {
  flex: 1;
  height: 70rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.coupon-btn {
  width: 140rpx;
  height: 70rpx;
  line-height: 70rpx;
  background-color: #07c160;
  color: #fff;
  font-size: 28rpx;
  border-radius: 8rpx;
  border: none;
}

.coupon-hint {
  margin-top: 15rpx;
  font-size: 24rpx;
  color: #999;
}

.coupon-applied {
  margin-top: 15rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.coupon-desc {
  font-size: 26rpx;
  color: #07c160;
}

.coupon-remove {
  font-size: 26rpx;
  color: #ff4d4f;
}

/* 商品列表 */
.cart-list {
  margin-bottom: 20rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  position: relative;
  margin-bottom: 20rpx;
}

.item-checkbox {
  margin-right: 20rpx;
}

.item-img {
  width: 150rpx;
  height: 150rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 30rpx;
  font-weight: bold;
}

.item-price {
  color: #ff4400;
  font-size: 28rpx;
  margin-top: 10rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}

.minus, .plus {
  width: 60rpx;
  height: 60rpx;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  border-radius: 8rpx;
}

.num {
  width: 80rpx;
  text-align: center;
  font-size: 28rpx;
}

.remove-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
}

/* 订单信息 */
.order-info {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-item .label {
  font-size: 28rpx;
  color: #666;
}

.info-item .value {
  font-size: 28rpx;
  color: #333;
}

.info-item .value.discount {
  color: #07c160;
}

.info-item .value .free {
  color: #07c160;
}

/* 底部结算栏 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.total-info {
  display: flex;
  align-items: center;
}

.total-info text:first-child {
  font-size: 28rpx;
  color: #666;
}

.total-price {
  color: #ff4400;
  font-size: 36rpx;
  font-weight: bold;
  margin-left: 10rpx;
}

.checkout-btn {
  background-color: #007aff;
  color: #fff;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 35rpx;
  padding: 0 50rpx;
  font-size: 28rpx;
}

.checkout-btn[disabled] {
  background-color: #ccc;
}