.cart-container {
  padding-bottom: 120rpx;
  background-color: var(--color-bg);
}

.cart-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  color: var(--color-text-muted);
}

.cart-empty text {
  margin: 30rpx 0;
}

/* ============================================
   Address Section
   ============================================ */
.address-section {
  margin-bottom: 20rpx;
  padding: 30rpx;
  background: var(--color-surface);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: all 0.3s;
  border: 1rpx solid var(--color-border);
}

.address-section:active {
  transform: scale(0.98);
  background-color: var(--color-bg-subtle);
}

.address-info .address-header {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.address-info .name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-right: 20rpx;
}

.address-info .phone {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.address-info .address-content {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.address-empty {
  display: flex;
  align-items: center;
  color: var(--color-text-muted);
}

.address-empty icon {
  margin-right: 10rpx;
}

.arrow-icon {
  color: var(--color-text-muted);
}

/* ============================================
   Select All Bar
   ============================================ */
.select-all-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: var(--color-surface);
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--color-border);
}

.select-all {
  display: flex;
  align-items: center;
}

.select-all text {
  margin-left: 10rpx;
  font-size: 28rpx;
  color: var(--color-text);
}

.selected-info {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* ============================================
   Coupon Section
   ============================================ */
.coupon-section {
  margin-bottom: 20rpx;
  padding: 20rpx 30rpx;
  background: var(--color-surface);
  border-radius: 12rpx;
  border: 1rpx solid var(--color-border);
}

.coupon-input-row {
  display: flex;
  align-items: center;
}

.coupon-input {
  flex: 1;
  height: 70rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background-color: var(--color-bg-subtle);
  margin-right: 20rpx;
}

.coupon-btn {
  width: 140rpx;
  height: 70rpx;
  line-height: 70rpx;
  background-color: var(--color-success);
  color: #fff;
  font-size: 28rpx;
  border-radius: 8rpx;
  border: none;
}

.coupon-hint {
  margin-top: 15rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.coupon-applied {
  margin-top: 15rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.coupon-desc {
  font-size: 26rpx;
  color: var(--color-success);
}

.coupon-remove {
  font-size: 26rpx;
  color: var(--color-price);
}

/* ============================================
   Cart Items List
   ============================================ */
.cart-list {
  margin-bottom: 20rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  position: relative;
  margin-bottom: 20rpx;
  background: var(--color-surface);
  border-radius: 12rpx;
  border: 1rpx solid var(--color-border);
}

.item-checkbox {
  margin-right: 20rpx;
}

.item-img {
  width: 150rpx;
  height: 150rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  background-color: var(--color-bg-subtle);
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.item-price {
  color: var(--color-price);
  font-size: 28rpx;
  margin-top: 10rpx;
  font-weight: 600;
}

.quantity-control {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}

.minus, .plus {
  width: 60rpx;
  height: 60rpx;
  background-color: var(--color-bg-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  border-radius: 8rpx;
  color: var(--color-text);
}

.minus {
  color: var(--color-text-secondary);
}

.plus {
  color: var(--color-accent);
}

.num {
  width: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--color-text);
}

.remove-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  color: var(--color-text-muted);
}

/* ============================================
   Order Info Summary
   ============================================ */
.order-info {
  background: var(--color-surface);
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--color-border);
}

.info-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-item .label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.info-item .value {
  font-size: 28rpx;
  color: var(--color-text);
}

.info-item .value.discount {
  color: var(--color-success);
}

.info-item .value .free {
  color: var(--color-success);
  font-weight: 600;
}

/* ============================================
   Footer Checkout Bar
   ============================================ */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: var(--color-surface);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(30, 58, 95, 0.1);
  border-top: 1rpx solid var(--color-border);
}

.total-info {
  display: flex;
  align-items: center;
}

.total-info text:first-child {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.total-price {
  color: var(--color-price);
  font-size: 36rpx;
  font-weight: 600;
  margin-left: 10rpx;
}

/* Checkout Button - Primary Navy */
.checkout-btn {
  background-color: var(--color-primary);
  color: #fff;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 35rpx;
  padding: 0 50rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.checkout-btn[disabled] {
  background-color: var(--color-text-muted);
}
