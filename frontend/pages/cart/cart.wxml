<view class="cart-container">
  <view class="cart-empty" wx:if="{{cartItems.length === 0}}">
    <icon type="info" size="64"></icon>
    <text>您的购物车还是空的哦</text>
    <button class="btn" bindtap="goToIndex">去逛逛</button>
  </view>

  <view class="cart-content" wx:else>
    <!-- 收货地址 -->
    <view class="address-section card" bindtap="selectAddress">
      <view class="address-info" wx:if="{{selectedAddress}}">
        <view class="address-header">
          <text class="name">{{selectedAddress.name}}</text>
          <text class="phone">{{selectedAddress.phone}}</text>
        </view>
        <view class="address-content">
          <text class="address-text">{{selectedAddress.province}}{{selectedAddress.city}}{{selectedAddress.district}}{{selectedAddress.detailAddress}}</text>
        </view>
      </view>
      <view class="address-empty" wx:else>
        <icon type="location" size="24"></icon>
        <text>请选择收货地址</text>
      </view>
      <icon class="arrow-icon" type="arrowright" size="16"></icon>
    </view>

    <!-- 全选栏 -->
    <view class="select-all-bar">
      <view class="select-all" bindtap="onToggleSelectAll">
        <icon type="{{selectedItems.length === cartItems.length ? 'success' : 'circle'}}" size="20" color="{{selectedItems.length === cartItems.length ? '#07c160' : '#999'}}"></icon>
        <text>全选</text>
      </view>
      <view class="selected-info">
        <text>已选 {{selectedItems.length}} 件</text>
      </view>
    </view>

    <!-- 商品列表 -->
    <view class="cart-list">
      <view class="cart-item card" wx:for="{{cartItems}}" wx:key="id">
        <view class="item-checkbox" bindtap="onToggleSelect" data-id="{{item.id}}">
          <icon type="{{selectedItems.includes(item.id) ? 'success' : 'circle'}}" size="20" color="{{selectedItems.includes(item.id) ? '#07c160' : '#999'}}"></icon>
        </view>
        <image class="item-img" src="{{item.imageUrl}}" mode="aspectFill" lazy-load="true"></image>
        <view class="item-info">
          <text class="item-name">{{item.name}}</text>
          <text class="item-price">￥{{item.price}}</text>
          <view class="quantity-control">
            <text class="minus" bindtap="onMinus" data-id="{{item.id}}">-</text>
            <text class="num">{{item.quantity}}</text>
            <text class="plus" bindtap="onPlus" data-id="{{item.id}}">+</text>
          </view>
        </view>
        <icon class="remove-btn" type="clear" size="20" bindtap="onRemove" data-id="{{item.id}}"></icon>
      </view>
    </view>

    <!-- 优惠券 -->
    <view class="coupon-section card">
      <view class="coupon-input-row">
        <input class="coupon-input" placeholder="请输入优惠码" value="{{couponCode}}" bindinput="onCouponInput" />
        <button class="coupon-btn" bindtap="onApplyCoupon">应用</button>
      </view>
      <view class="coupon-hint" wx:if="{{!couponApplied}}">
        <text>提示: 可输入 DISCOUNT10, SAVE5 等测试优惠码</text>
      </view>
      <view class="coupon-applied" wx:if="{{couponApplied}}">
        <text class="coupon-desc">{{couponApplied.description}}</text>
        <text class="coupon-remove" bindtap="onRemoveCoupon">取消</text>
      </view>
    </view>

    <!-- 订单信息 -->
    <view class="order-info card">
      <view class="info-item">
        <text class="label">商品合计</text>
        <text class="value">￥{{selectedPrice}}</text>
      </view>
      <view class="info-item">
        <text class="label">运费</text>
        <text class="value">
          <text wx:if="{{shippingFee === 0}}" class="free">免运费</text>
          <text wx:else>￥{{shippingFee}}</text>
        </text>
      </view>
      <view class="info-item">
        <text class="label">优惠</text>
        <text class="value discount">-￥{{couponDiscount}}</text>
      </view>
    </view>

    <view class="footer">
      <view class="total-info">
        <text>合计：</text>
        <text class="total-price">￥{{selectedPrice + shippingFee - couponDiscount}}</text>
      </view>
      <button class="checkout-btn" bindtap="onCheckout" disabled="{{selectedItems.length === 0}}">去结算</button>
    </view>
  </view>
</view>
