<view class="cart-container">
  <view class="cart-empty" wx:if="{{cartItems.length === 0}}">
    <icon type="info" size="64"></icon>
    <text>您的购物车还是空的哦</text>
    <navigator class="btn" open-type="switchTab" url="/pages/index/index">去逛逛</navigator>
  </view>

  <view class="cart-content" wx:else>
    <!-- 收货地址 -->
    <navigator class="address-section card" open-type="navigate" bindtap="selectAddress">
      <view class="address-info" wx:if="{{selectedAddress}}">
        <view class="address-header">
          <text class="name">{{selectedAddress.name}}</text>
          <text class="phone">{{selectedAddress.phone}}</text>
        </view>
        <view class="address-content">
          <text class="address-text">{{selectedAddress.province}}{{selectedAddress.city}}{{selectedAddress.district}}{{selectedAddress.detailAddress}}</text>
        </view>
      </view>
      <view class="address-empty" wx:else>
        <icon type="location" size="24"></icon>
        <text>请选择收货地址</text>
      </view>
      <icon class="arrow-icon" type="arrowright" size="16"></icon>
    </navigator>

    <!-- 全选栏 -->
    <view class="select-all-bar">
      <checkbox-group bindchange="onSelectAll">
        <label class="select-all">
          <checkbox value="all" checked="{{selectedItems.length === cartItems.length && cartItems.length > 0}}" />
          <text>全选</text>
        </label>
      </checkbox-group>
      <view class="selected-info">
        <text>已选 {{selectedItems.length}} 件</text>
      </view>
    </view>

    <!-- 商品列表 -->
    <checkbox-group bindchange="onCheckboxChange">
      <view class="cart-list">
        <view class="cart-item card" wx:for="{{cartItems}}" wx:key="id">
          <label class="item-checkbox">
            <checkbox value="{{item.id}}" />
          </label>
          <image class="item-img" src="{{item.imageUrl}}" mode="aspectFill" lazy-load="true"></image>
          <view class="item-info">
            <text class="item-name">{{item.name}}</text>
            <text class="item-price">￥{{item.price}}</text>
            <view class="quantity-control">
              <button class="minus" size="mini" catchtap="onMinus" data-id="{{item.id}}">-</button>
              <input type="number" class="num" value="{{item.quantity}}" data-id="{{item.id}}" bindchange="onQuantityChange" />
              <button class="plus" size="mini" catchtap="onPlus" data-id="{{item.id}}">+</button>
            </view>
          </view>
          <button class="remove-btn" size="mini" catchtap="onRemove" data-id="{{item.id}}">×</button>
        </view>
      </view>
    </checkbox-group>

    <!-- 订单信息 -->
    <view class="order-info card">
      <view class="info-item">
        <text class="label">商品合计</text>
        <text class="value">￥{{selectedPrice}}</text>
      </view>
      <view class="info-item">
        <text class="label">运费</text>
        <text class="value">
          <text wx:if="{{shippingFee === 0}}" class="free">免运费</text>
          <text wx:else>￥{{shippingFee}}</text>
        </text>
      </view>
    </view>

    <view class="footer">
      <view class="total-info">
        <text>合计：</text>
        <text class="total-price">￥{{totalPrice}}</text>
      </view>
      <button class="checkout-btn" bindtap="onCheckout" disabled="{{selectedItems.length === 0}}">去结算</button>
    </view>
  </view>
</view>
