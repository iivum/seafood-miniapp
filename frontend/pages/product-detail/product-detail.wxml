<view class="detail-container">
  <image class="banner" src="{{product.imageUrl}}" mode="aspectFill"></image>
  
  <view class="info card">
    <text class="price">￥{{product.price}}</text>
    <text class="name">{{product.name}}</text>
    <text class="desc">{{product.description}}</text>
  </view>

  <view class="section card">
    <view class="section-title">商品参数</view>
    <view class="param-item">
      <text class="label">分类</text>
      <text class="value">{{product.category}}</text>
    </view>
    <view class="param-item">
      <text class="label">库存</text>
      <text class="value">{{product.stock}} 件</text>
    </view>
  </view>

  <view class="footer">
    <view class="home-btn" bindtap="goToHome">
      <icon type="home" size="24"></icon>
      <text>首页</text>
    </view>
    <view class="cart-btn" bindtap="goToCart">
      <icon type="cart" size="24"></icon>
      <text>购物车</text>
    </view>
    <button class="add-cart" bindtap="onAddToCart">加入购物车</button>
    <button class="buy-now" bindtap="onBuyNow">立即购买</button>
  </view>
</view>
