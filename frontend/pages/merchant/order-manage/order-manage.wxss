.order-manage-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  padding: 30rpx;
  background-color: #fff;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
}

/* Status Filter */
.status-filter {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.status-tab {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  margin-right: 20rpx;
  margin-bottom: 10rpx;
}

.status-tab.active {
  background-color: #07c160;
  color: #fff;
}

/* Loading & Empty */
.loading-state,
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}

/* Order List */
.order-list {
  padding: 20rpx;
}

.order-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-number {
  font-size: 26rpx;
  color: #666;
}

.order-status {
  font-size: 26rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.status-pending {
  background-color: #fff3cd;
  color: #ff9800;
}

.status-paid {
  background-color: #e8f5e9;
  color: #4caf50;
}

.status-shipped {
  background-color: #e3f2fd;
  color: #2196f3;
}

.status-delivered,
.status-completed {
  background-color: #e8f5e9;
  color: #4caf50;
}

.status-cancelled {
  background-color: #ffebee;
  color: #f44336;
}

.status-refunded {
  background-color: #f5f5f5;
  color: #999;
}

.order-items {
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-product {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.product-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.product-qty {
  font-size: 26rpx;
  color: #999;
  margin-left: 20rpx;
}

.product-price {
  font-size: 28rpx;
  color: #333;
  margin-left: 20rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 15rpx;
}

.order-total {
  display: flex;
  align-items: baseline;
}

.order-total text {
  font-size: 26rpx;
  color: #666;
}

.total-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.order-actions {
  display: flex;
  gap: 15rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
}

.action-btn.ship {
  background-color: #e3f2fd;
  color: #2196f3;
}

.action-btn.complete {
  background-color: #e8f5e9;
  color: #4caf50;
}

.action-btn.cancel {
  background-color: #ffebee;
  color: #f44336;
}

.order-info {
  display: flex;
  gap: 20rpx;
  padding-top: 15rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 10rpx;
}

.info-text {
  font-size: 24rpx;
  color: #999;
}
