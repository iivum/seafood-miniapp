{
  "compilerOptions": {
    /* Visit https://aka.ms/tsconfig to read more about this file */

    /* Projects */
    // "incremental": true,                              /* Save .tsbuildinfo files to allow for incremental compilation of projects. */
    // "composite": true,                                /* Enable constraints that can be used to declare project dependencies. */
    // "tsBuildInfoFile": "./.tsbuildinfo",              /* Specify the path to .tsbuildinfo incremental compilation file. */
    // "disableReferencedProjectLoad": true,             /* Disable loading projects referenced in the arguments when the project is opened in a new tab in VS Code. */

    /* Language and Environment */
    "target": "ES2020",                                  /* Set the JavaScript language version emitted by your code. */
    // "lib": [],                                        /* Specify a set of bundled library declaration files that describe the runtime environment. */
    // "jsx": "preserve",                                /* Specify what JSX code is generated. */
    // "experimentalDecorators": true,                   /* Enable experimental support for TC39 stage 2 draft decorators. */
    // "emitDecoratorMetadata": true,                    /* Emit design-type metadata for decorated declarations in source. */
    // "jsxFactory": "",                                 /* Specify the JSX factory function used when targeting React JSX emit, e.g. React.createElement. */
    // "jsxFragmentFactory": "",                         /* Specify the JSX fragment factory function used when targeting React JSX emit, e.g. React.Fragment. */
    // "jsxImportSource": "",                            /* Specify module specifier used to import the JSX factory function. */
    // "reactNamespace": "",                             /* Specify the object invoked for React.createElement calls. */
    // "noLib": true,                                    /* Disable standard type checking for all library files. */
    // "useDefineForClassFields": true,                  /* Emit ECMAScript-standard-compliant class fields. */
    // "moduleDetection": "auto",                        /* Specify what method is used to detect module files for compilation. */

    /* Modules */
    "module": "commonjs",                                /* Specify what module code is generated. */
    // "rootDir": "./",                                  /* Specify the root folder within your source files. */
    // "moduleResolution": "node",                       /* Specify how TypeScript looks up a file from a given module specifier. */
    // "baseUrl": "./",                                  /* Specify the base directory to resolve non-relative module names. */
    // "paths": {},                                      /* Specify path mapping entries that are substituted by the module resolver. */
    // "rootDirs": [],                                   /* Allow multiple folders to be treated as one when resolving modules. */
    // "typeRoots": [],                                  /* Specify multiple folders that act as <reference noDefaultLib />. */
    // "types": [],                                      /* Specify type package names to be included without a path. */
    // "allowUmdGlobalAccess": true,                     /* Allow accessing UMD globals from modules. */
    "moduleResolution": "node",                          /* Enable Node.js style module resolution. */
    // "resolveJsonModule": true,                        /* Enable importing .json files. */
    // "allowArbitraryExtensions": true,                 /* Enable importing files with any extension, provided a declaration file is present. */
    // "resolvePackageJsonExports": true,                /* Turn on imports using the package.json 'exports' field. */
    // "resolvePackageJsonImports": true,                /* Turn on imports using the package.json 'imports' field. */
    // "customConditions": [],                           /* Specify custom conditions for resolving module resolution. */
    // "resolveJsonModule": true,                        /* Enable importing .json files. */
    // "allowUmdGlobalAccess": true,                     /* Allow accessing UMD globals from modules. */

    /* JavaScript Support */
    // "allowJs": true,                                  /* Allow JavaScript files to be compiled. */
    // "checkJs": true,                                  /* Enable error reporting in type-checked JavaScript files. */
    // "declarationMap": true,                           /* Create sourcemaps for d.ts files. */
    // "downlevelIteration": true,                       /* Emit more compliant, but verbose and less performant JavaScript for iteration. */
    // "esModuleInterop": true,                          /* Emit additional JavaScript to facilitate support for importing CommonJS modules. */
    // "preserveSymlinks": true,                         /* Disable symlinks to .d.ts files. */
    // "skipDefaultLibCheck": true,                      /* Skip type checking .d.ts files that come from the standard library. */

    /* Emit */
    // "declaration": true,                              /* Generate .d.ts files from TypeScript and JavaScript files in your project. */
    // "declarationMap": true,                           /* Create sourcemaps for d.ts files. */
    // "emitDeclarationOnly": true,                      /* Only output d.ts files and not JavaScript files. */
    // "sourceMap": true,                                /* Create source maps for emitted JavaScript files. */
    // "inlineSourceMap": true,                          /* Emit a single source map for all emitted source files. */
    // "outFile": "./",                                  /* Specify a file that bundles all outputs into one JavaScript file. */
    // "outDir": "./",                                   /* Specify an output folder for all emitted files. */
    // "removeComments": true,                           /* Disable emitting comments. */
    "noEmit": false,                                     /* Disable emitting output. */
    // "importHelpers": true,                            /* Allow importing helper functions from tslib once per module, rather than including them per-file. */
    // "importsNotUsedAsValues": "remove",               /* Specify emit/checking behavior for imports that are not used. */
    // "downlevelIteration": true,                       /* Emit more compliant, but verbose and less performant JavaScript for iteration. */
    // "sourceRoot": "",                                 /* Specify the root path for debuggers to find the source code. */
    // "mapRoot": "",                                    /* Specify the location where debugger property maps are emitted. */
    // "inlineSources": true,                            /* Emit the source alongside the sourcemaps instead of the separate file. */
    // "emitBOM": true,                                  /* Emit the UTF-8 Byte Order Mark. */
    // "newLine": "crlf",                                /* Set the newline character for emitting files. */
    // "stripInternal": true,                            /* Disable emitting declarations with an internal .tslintfilter. */
    // "noEmitHelpers": true,                            /* Disable generating custom helper functions like __extends in emitted code. */
    // "noEmitOnError": true,                            /* Disable emitting files if any type checking errors are reported. */
    // "preserveConstEnums": true,                       /* Preserve const enums in JavaScript output. */
    // "declarationDir": "./",                           /* Specify the output directory for generated declaration files. */

    /* Interop Constraints */
    "isolatedModules": true,                             /* Ensure that each file can be safely transpiled without relying on other imports. */
    "verbatimModuleSyntax": false,                       /* Do not transform or elide any imports or exports not marked as type-only, even if they would serve no purpose. */
    // "allowSyntheticDefaultImports": true,             /* Allow 'import x from y' when no default export is present. */
    "esModuleInterop": true,                             /* Emit additional JavaScript to facilitate support for importing CommonJS modules. */
    // "preserveSymlinks": true,                         /* Disable symlinks to .d.js files. */
    "forceConsistentCasingInFileNames": true,            /* Ensure that casing is correct in imports. */
    "module": "CommonJS",                                /* Specify module code to be emitted. */

    /* Type Checking */
    "strict": true,                                      /* Enable all strict type-checking options. */
    // "noImplicitAny": true,                            /* Enable error reporting for expressions and declarations with an implicit any type. */
    // "strictNullChecks": true,                         /* When type checking, take into account that null and undefined are not part of any type. */
    // "strictFunctionTypes": true,                      /* When checking function types, check the parameter types more strictly. */
    // "strictBindCallApply": true,                      /* Check that the argument types at bind, call and apply are correct for methods. */
    // "strictPropertyInitialization": true,             /* Check for class properties that are declared but not set in class constructor. */
    // "noImplicitThis": true,                           /* Enable error reporting when the value of this is given the type any. */
    // "useUnknownInCatchVariables": true,               /* Default catch clause variables as 'unknown' instead of 'any'. */
    // "alwaysStrict": true,                             /* Ensure that the compiler always emits strict mode code. */
    // "noUnusedLocals": true,                           /* Enable error reporting when local variables are not assigned. */
    // "noUnusedParameters": true,                       /* Enable error reporting when parameters are not assigned. */
    // "exactOptionalPropertyTypes": true,               /* Interpret optional property types as written, rather than adding 'undefined'. */
    // "noImplicitReturns": true,                         /* Enable error reporting for codepaths that do not explicitly return in a function. */
    // "noFallthroughCasesInSwitch": true,               /* Enable error reporting for fallthrough cases in switch statements. */
    // "noUncheckedIndexedAccess": true,                 /* Add 'undefined' to a type when accessed using an index. */
    // "noImplicitOverride": true,                       /* Ensure overriding members in derived classes are always marked with an override modifier. */
    // "noPropertyAccessFromIndexSignature": true,       /* Require that for class objects, members are accessed using the dot accessors rather than the bracket. */
    // "allowUnusedLabels": true,                        /* Disable error reporting for unused labels. */
    // "allowUnreachableCode": true,                     /* Disable error reporting for unreachable code. */

    /* Completeness */
    // "skipDefaultLibCheck": true,                      /* Skip type checking .d.ts files that come from the standard library. */
    "skipLibCheck": true                                 /* Skip type checking of all .d.ts files. */
  },

  /* Type packages: Jest + WeChat Mini-Program types */
  "types": ["jest", "miniprogram-api-typings"]
}