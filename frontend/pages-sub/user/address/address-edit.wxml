<view class="address-edit-container">
  <form bindsubmit="saveAddress">
    <!-- 收件人信息 -->
    <view class="form-section">
      <view class="form-item">
        <text class="label">收件人</text>
        <input 
          class="input" 
          name="name"
          placeholder="请输入收件人姓名" 
          value="{{address.name || ''}}"
          required
        />
      </view>
      
      <view class="form-item">
        <text class="label">手机号</text>
        <input 
          class="input" 
          name="phone"
          type="number"
          placeholder="请输入手机号" 
          value="{{address.phone || ''}}"
          maxlength="11"
          required
        />
      </view>
    </view>

    <!-- 地址信息 -->
    <view class="form-section">
      <view class="form-item">
        <text class="label">所在地区</text>
        <picker 
          mode="region" 
          name="region"
          value="{{regionIndex}}" 
          range="{{regionList}}"
          bindchange="onRegionChange"
        >
          <view class="picker-input">
            <text class="{{address.province ? 'selected' : 'placeholder'}}">
              {{address.province ? address.province + ' ' + address.city + ' ' + address.district : '请选择省市区'}}
            </text>
            <icon type="arrowdown" size="16"></icon>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="label">详细地址</text>
        <textarea 
          class="textarea" 
          name="detailAddress"
          placeholder="请输入街道、楼栋、门牌号等详细信息"
          value="{{address.detailAddress || ''}}"
          auto-height
          maxlength="100"
          required
        />
      </view>
    </view>

    <!-- 设置默认地址 -->
    <view class="form-section">
      <view class="form-item switch-item">
        <text class="label">设为默认地址</text>
        <switch name="isDefault" checked="{{address.isDefault || false}}" color="#667eea" />
      </view>
    </view>

    <!-- 错误提示 -->
    <text class="error-tip" wx:if="{{errorMsg}}">{{errorMsg}}</text>

    <!-- 保存按钮 -->
    <button class="save-btn" form-type="submit" loading="{{isSaving}}">
      保存收货地址
    </button>
  </form>
</view>