/* 地址列表页面样式 */
.address-list-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 20rpx;
  box-sizing: border-box;
}

/* 地址列表 */
.address-list {
  padding-bottom: calc(140rpx + var(--safe-area-bottom));
}

.address-item {
  margin-bottom: 20rpx;
  padding: 30rpx;
  background: var(--color-surface);
  border-radius: 12rpx;
  transition: all 0.3s;
}

.address-item:active {
  transform: scale(0.98);
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.address-header .name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-right: 20rpx;
}

.address-header .phone {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  flex: 1;
}

.address-header .default-tag {
  background: var(--color-price);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.address-content {
  margin-bottom: 20rpx;
}

.address-content .address-text {
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.5;
}

.address-actions {
  display: flex;
  justify-content: flex-end;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--color-divider);
}

.address-actions > .action-item + .action-item {
  margin-left: 40rpx;
}

.action-item {
  display: flex;
  align-items: center;
  color: var(--color-text-secondary);
  font-size: 26rpx;
  transition: all 0.3s;
}

.action-item:active {
  color: var(--color-primary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.empty-state icon {
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-state .empty-text {
  font-size: 32rpx;
  color: var(--color-text-muted);
  margin-bottom: 10rpx;
}

.empty-state .empty-subtext {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

/* 添加地址按钮 */
.add-address-btn {
  position: fixed;
  bottom: calc(40rpx + var(--safe-area-bottom));
  left: 40rpx;
  right: 40rpx;
  height: 90rpx;
  background: var(--color-primary);
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  box-shadow: 0 10rpx 30rpx rgba(30, 58, 95, 0.3);
  transition: all 0.3s;
}

.add-address-btn:active {
  transform: scale(0.98);
  box-shadow: 0 5rpx 20rpx rgba(30, 58, 95, 0.2);
}

.add-address-btn icon {
  margin-right: 10rpx;
}

/* 选择模式样式 */
.address-item.select-mode {
  position: relative;
  padding-left: 80rpx;
}

.address-item.select-mode::before {
  content: '';
  position: absolute;
  left: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 50%;
  transition: all 0.3s;
}

.address-item.select-mode.selected::before {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.address-item.select-mode.selected::after {
  content: '✓';
  position: absolute;
  left: 36rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #fff;
  font-size: 24rpx;
}