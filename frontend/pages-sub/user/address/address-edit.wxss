/* 地址编辑页面样式 */
.address-edit-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 表单区块 */
.form-section {
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  padding: 0 30rpx;
}

.form-item {
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item .label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.form-item .input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.form-item .input:focus {
  border-color: #667eea;
  background: #fff;
}

/* 地区选择器 */
.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.picker-input .placeholder {
  color: #999;
}

.picker-input .selected {
  color: #333;
}

/* 文本域 */
.form-item .textarea {
  width: 100%;
  min-height: 120rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.form-item .textarea:focus {
  border-color: #667eea;
  background: #fff;
}

/* 开关项 */
.switch-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 保存按钮 */
.save-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 45rpx;
  color: #fff;
  font-size: 32rpx;
  border: none;
  margin-top: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s;
}

.save-btn:active {
  transform: scale(0.98);
  box-shadow: 0 5rpx 20rpx rgba(102, 126, 234, 0.3);
}

.save-btn[disabled] {
  background: #ccc;
  box-shadow: none;
}

/* 错误提示 */
.error-tip {
  display: block;
  text-align: center;
  color: #ff5252;
  font-size: 26rpx;
  margin-top: 20rpx;
}

/* 删除按钮 */
.delete-btn {
  width: 100%;
  height: 90rpx;
  background: #ff5252;
  border-radius: 45rpx;
  color: #fff;
  font-size: 32rpx;
  border: none;
  margin-top: 20rpx;
  transition: all 0.3s;
}

.delete-btn:active {
  transform: scale(0.98);
}