<view class="login-container">
  <!-- Logo和标题 -->
  <view class="login-header">
    <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
    <text class="title">海鲜生鲜商城</text>
    <text class="subtitle">新鲜海鲜，品质保证</text>
  </view>

  <!-- 登录方式切换 -->
  <view class="login-tabs">
    <text class="tab-item {{activeTab === 'wechat' ? 'active' : ''}}" bindtap="switchTab" data-tab="wechat">微信登录</text>
    <text class="tab-item {{activeTab === 'phone' ? 'active' : ''}}" bindtap="switchTab" data-tab="phone">手机号登录</text>
  </view>

  <!-- 微信登录表单 -->
  <view class="login-form" wx:if="{{activeTab === 'wechat'}}">
    <view class="form-content">
      <button class="wechat-login-btn" bindtap="wechatLogin" loading="{{isLoading}}">
        <icon type="wechat" size="24" color="#fff"></icon>
        <text>微信一键登录</text>
      </button>
      
      <view class="tips">
        <text>点击登录即表示同意</text>
        <text class="link" bindtap="showAgreement">《用户协议》</text>
        <text>和</text>
        <text class="link" bindtap="showPrivacy">《隐私政策》</text>
      </view>
    </view>
  </view>

  <!-- 手机号登录表单 -->
  <view class="login-form" wx:if="{{activeTab === 'phone'}}">
    <view class="form-content">
      <!-- 手机号输入 -->
      <view class="input-item">
        <text class="label">手机号</text>
        <input 
          class="input" 
          type="number" 
          placeholder="请输入手机号" 
          value="{{phone}}"
          bindinput="onPhoneInput"
          maxlength="11"
        />
      </view>

      <!-- 验证码输入 -->
      <view class="input-item">
        <text class="label">验证码</text>
        <view class="verify-row">
          <input 
            class="input verify-input" 
            type="number" 
            placeholder="请输入验证码" 
            value="{{verifyCode}}"
            bindinput="onVerifyCodeInput"
            maxlength="6"
          />
          <button 
            class="verify-btn {{isCounting ? 'disabled' : ''}}" 
            bindtap="getVerifyCode"
            disabled="{{isCounting}}"
          >
            {{countDownText}}
          </button>
        </view>
      </view>

      <!-- 密码输入（可选） -->
      <view class="input-item" wx:if="{{loginMode === 'register'}}">
        <text class="label">设置密码</text>
        <input 
          class="input" 
          type="password" 
          placeholder="请设置6-20位密码" 
          value="{{password}}"
          bindinput="onPasswordInput"
          maxlength="20"
        />
      </view>

      <!-- 登录按钮 -->
      <button 
        class="login-btn {{!isFormValid ? 'disabled' : ''}}" 
        bindtap="phoneLogin"
        loading="{{isLoading}}"
        disabled="{{!isFormValid || isLoading}}"
      >
        登录/注册
      </button>

      <!-- 协议同意 -->
      <view class="agreement">
        <checkbox value="agree" checked="{{agreement}}" bindtap="toggleAgreement" />
        <text>我已阅读并同意</text>
        <text class="link" bindtap="showAgreement">《用户协议》</text>
        <text>和</text>
        <text class="link" bindtap="showPrivacy">《隐私政策》</text>
      </view>

      <!-- 错误提示 -->
      <text class="error-tip" wx:if="{{errorMsg}}">{{errorMsg}}</text>
    </view>
  </view>

  <!-- 加载提示 -->
  <view class="loading-mask" wx:if="{{isLoading}}">
    <view class="loading-content">
      <icon type="loading" size="48" color="#007aff"></icon>
      <text>登录中...</text>
    </view>
  </view>
</view>