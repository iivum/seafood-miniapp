.user-manage-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  padding: 30rpx;
  background-color: #fff;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
}

/* Role Filter */
.role-filter {
  display: flex;
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.role-tab {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  margin-right: 20rpx;
}

.role-tab.active {
  background-color: #07c160;
  color: #fff;
}

/* Loading & Empty */
.loading-state,
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}

/* User List */
.user-list {
  padding: 20rpx;
}

.user-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: #f0f0f0;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-info {
  flex: 1;
  margin-left: 20rpx;
}

.user-header {
  display: flex;
  align-items: center;
}

.user-header > *:not(:first-child) {
  margin-left: 15rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.user-role {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.role-user {
  background-color: #e3f2fd;
  color: #2196f3;
}

.role-admin {
  background-color: #fff3cd;
  color: #ff9800;
}

.role-disabled {
  background-color: #f5f5f5;
  color: #999;
}

.user-detail {
  display: flex;
  margin-top: 10rpx;
}

.user-detail > *:not(:first-child) {
  margin-left: 20rpx;
}

.detail-text {
  font-size: 24rpx;
  color: #999;
}

.user-actions {
  display: flex;
  flex-direction: column;
}

.user-actions > *:not(:first-child) {
  margin-top: 10rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  text-align: center;
}

.action-btn.view {
  background-color: #e3f2fd;
  color: #2196f3;
}

.action-btn.role {
  background-color: #fff3cd;
  color: #ff9800;
}

.action-btn.disable {
  background-color: #ffebee;
  color: #f44336;
}

.action-btn.enable {
  background-color: #e8f5e9;
  color: #4caf50;
}
