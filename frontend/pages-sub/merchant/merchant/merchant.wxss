.merchant-container {
  padding: 20rpx;
}

.header {
  padding: 40rpx;
  background-color: var(--color-primary);
  color: #fff;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 32rpx;
  display: block;
}

.shop-name {
  font-size: 48rpx;
  font-weight: bold;
}

.stats {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  background-color: var(--color-surface);
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-primary);
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.arrow {
  color: var(--color-text-muted);
}
