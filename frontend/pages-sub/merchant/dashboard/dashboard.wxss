.dashboard-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background-color: #fff;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.header-date {
  font-size: 26rpx;
  color: #999;
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}

.dashboard-content {
  padding: 20rpx;
}

/* Stat Cards */
.stat-card {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.stat-icon {
  font-size: 60rpx;
  margin-right: 30rpx;
}

.stat-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  font-size: 26rpx;
  color: #666;
  margin-top: 5rpx;
}

.stat-trend {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.stat-trend.up {
  color: #07c160;
}

.stat-trend.down {
  color: #ff4d4f;
}

/* Quick Actions */
.quick-actions {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 10rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}
