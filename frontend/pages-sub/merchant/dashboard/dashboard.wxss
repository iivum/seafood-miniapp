.dashboard-container {
  min-height: 100vh;
  background-color: var(--color-bg);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background-color: var(--color-surface);
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
}

.header-date {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx;
  color: var(--color-text-muted);
  font-size: 28rpx;
}

.dashboard-content {
  padding: 20rpx;
}

/* Stat Cards */
.stat-card {
  display: flex;
  align-items: center;
  background-color: var(--color-surface);
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.stat-icon {
  font-size: 60rpx;
  margin-right: 30rpx;
}

.stat-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--color-text);
}

.stat-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 5rpx;
}

.stat-trend {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.stat-trend.up {
  color: var(--color-success);
}

.stat-trend.down {
  color: var(--color-price);
}

/* Quick Actions */
.quick-actions {
  background-color: var(--color-surface);
  border-radius: 12rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 30rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 10rpx;
  background-color: var(--color-bg-subtle);
  border-radius: 12rpx;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}
