<view class="order-manage-container">
  <!-- Header -->
  <view class="header">
    <view class="header-title">订单管理</view>
  </view>

  <!-- Status Filter -->
  <view class="status-filter">
    <view
      class="status-tab {{selectedStatus === item.value ? 'active' : ''}}"
      wx:for="{{statusOptions}}"
      wx:key="value"
      bindtap="onStatusChange"
      data-status="{{item.value}}"
    >
      <text>{{item.label}}</text>
    </view>
  </view>

  <!-- Loading -->
  <view class="loading-state" wx:if="{{isLoading}}">
    <text>加载中...</text>
  </view>

  <!-- Empty -->
  <view class="empty-state" wx:elif="{{isEmpty}}">
    <text>暂无订单</text>
  </view>

  <!-- Order List -->
  <view class="order-list" wx:else>
    <view class="order-item" wx:for="{{orders}}" wx:key="id">
      <view class="order-header">
        <text class="order-number">订单号: {{item.orderNumber}}</text>
        <text class="order-status {{getStatusClass(item.status)}}">{{getStatusText(item.status)}}</text>
      </view>

      <view class="order-items">
        <view class="order-product" wx:for="{{item.items}}" wx:for-item="p" wx:key="productId">
          <text class="product-name">{{p.name}}</text>
          <text class="product-qty">x{{p.quantity}}</text>
          <text class="product-price">￥{{p.price}}</text>
        </view>
      </view>

      <view class="order-footer">
        <view class="order-total">
          <text>合计: </text>
          <text class="total-price">￥{{item.totalPrice}}</text>
        </view>
        <view class="order-actions">
          <text wx:if="{{item.status === 'PAID'}}" class="action-btn ship" bindtap="onShipOrder" data-order="{{item}}">发货</text>
          <text wx:if="{{item.status === 'SHIPPED'}}" class="action-btn complete" bindtap="onCompleteOrder" data-order="{{item}}">完成</text>
          <text wx:if="{{item.status === 'PENDING_PAYMENT'}}" class="action-btn cancel" bindtap="onCancelOrder" data-order="{{item}}">取消</text>
        </view>
      </view>

      <view class="order-info">
        <text class="info-text">用户: {{item.userId}}</text>
        <text class="info-text" wx:if="{{item.trackingNumber}}">运单号: {{item.trackingNumber}}</text>
      </view>
    </view>
  </view>
</view>
