.order-manage-container {
  min-height: 100vh;
  background-color: var(--color-bg-subtle);
}

.header {
  padding: 30rpx;
  background-color: var(--color-surface);
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
}

/* Status Filter */
.status-filter {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  background-color: var(--color-surface);
  border-bottom: 1rpx solid var(--color-border);
}

.status-tab {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background-color: var(--color-bg-subtle);
  border-radius: 8rpx;
  margin-right: 20rpx;
  margin-bottom: 10rpx;
}

.status-tab.active {
  background-color: var(--color-primary);
  color: #fff;
}

/* Loading & Empty */
.loading-state,
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx;
  color: var(--color-text-muted);
  font-size: 28rpx;
}

/* Order List */
.order-list {
  padding: 20rpx;
}

.order-item {
  background-color: var(--color-surface);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.order-number {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.order-status {
  font-size: 26rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.status-pending {
  background-color: #fff3cd;
  color: var(--color-accent);
}

.status-paid {
  background-color: var(--color-bg-subtle);
  color: var(--color-primary);
}

.status-shipped {
  background-color: #e3f2fd;
  color: #2196f3;
}

.status-delivered,
.status-completed {
  background-color: var(--color-bg-subtle);
  color: var(--color-success);
}

.status-cancelled {
  background-color: #ffebee;
  color: var(--color-price);
}

.status-refunded {
  background-color: var(--color-bg-subtle);
  color: var(--color-text-muted);
}

.order-items {
  padding: 15rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.order-product {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.product-name {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
}

.product-qty {
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin-left: 20rpx;
}

.product-price {
  font-size: 28rpx;
  color: var(--color-text);
  margin-left: 20rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 15rpx;
}

.order-total {
  display: flex;
  align-items: baseline;
}

.order-total text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.total-price {
  font-size: 32rpx;
  color: var(--color-price);
  font-weight: bold;
}

.order-actions {
  display: flex;
  margin: -5rpx 0;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  margin: 5rpx;
}

.action-btn.ship {
  background-color: #e3f2fd;
  color: #2196f3;
}

.action-btn.complete {
  background-color: var(--color-bg-subtle);
  color: var(--color-success);
}

.action-btn.cancel {
  background-color: #ffebee;
  color: var(--color-price);
}

.order-info {
  display: flex;
  flex-wrap: wrap;
  padding-top: 15rpx;
  border-top: 1rpx solid var(--color-border);
  margin-top: 10rpx;
  margin: -5rpx;
}

.info-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin: 5rpx;
}
