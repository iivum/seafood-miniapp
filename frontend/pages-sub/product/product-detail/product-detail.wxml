<view class="detail-container">
  <image class="banner" src="{{product.imageUrl}}" mode="aspectFill" lazy-load="{{true}}"></image>

  <view class="info card">
    <text class="price">￥{{product.price}}</text>
    <text class="name">{{product.name}}</text>
    <text class="desc">{{product.description}}</text>
  </view>

  <view class="section card">
    <view class="section-title">商品参数</view>
    <view class="param-item">
      <text class="label">分类</text>
      <text class="value">{{product.category}}</text>
    </view>
    <view class="param-item">
      <text class="label">库存</text>
      <text class="value">{{product.stock}} 件</text>
    </view>
  </view>

  <!-- Recommendations Section -->
  <view class="recommendations card" wx:if="{{recommendations.length > 0}}">
    <view class="section-title">商品推荐</view>
    <block wx:for="{{recommendations}}" wx:key="type">
      <view class="recommend-group">
        <view class="recommend-header">
          <text class="recommend-title">{{item.reason}}</text>
        </view>
        <scroll-view class="recommend-scroll" scroll-x="{{true}}">
          <view class="recommend-list">
            <view
              class="recommend-item"
              wx:for="{{item.products}}"
              wx:key="id"
              wx:for-item="recProduct"
              bindtap="goToProductDetail"
              data-id="{{recProduct.id}}"
            >
              <image class="recommend-img" src="{{recProduct.imageUrl}}" mode="aspectFill" lazy-load="{{true}}"></image>
              <text class="recommend-name">{{recProduct.name}}</text>
              <text class="recommend-price">￥{{recProduct.price}}</text>
            </view>
          </view>
        </scroll-view>
      </view>
    </block>
  </view>

  <!-- Loading recommendations -->
  <view class="loading-recommendations" wx:if="{{isLoadingRecommendations}}">
    <text>加载推荐中...</text>
  </view>

  <view class="footer">
    <view class="home-btn" bindtap="goToHome">
      <icon type="home" size="24"></icon>
      <text>首页</text>
    </view>
    <view class="cart-btn" bindtap="goToCart">
      <icon type="cart" size="24"></icon>
      <text>购物车</text>
    </view>
    <button class="add-cart" bindtap="onAddToCart">加入购物车</button>
    <button class="buy-now" bindtap="onBuyNow">立即购买</button>
  </view>
</view>
