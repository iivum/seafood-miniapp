.detail-container {
  padding-bottom: 120rpx;
  background-color: var(--color-bg);
}

.banner {
  width: 100%;
  height: 600rpx;
  background-color: var(--color-bg-subtle);
}

.info {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  background-color: var(--color-surface);
  margin-bottom: 20rpx;
}

.price {
  color: var(--color-price);
  font-size: 48rpx;
  font-weight: 600;
}

.name {
  font-size: 36rpx;
  font-weight: 600;
  margin-top: 20rpx;
  color: var(--color-text);
  line-height: 1.3;
}

.desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-top: 15rpx;
  line-height: 1.6;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: var(--color-text);
}

.param-item {
  display: flex;
  justify-content: space-between;
  padding: 15rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.param-item:last-child {
  border-bottom: none;
}

.label {
  color: var(--color-text-secondary);
}

.value {
  color: var(--color-text);
}

/* ============================================
   Footer Action Bar
   ============================================ */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: var(--color-surface);
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(30, 58, 95, 0.1);
  border-top: 1rpx solid var(--color-border);
}

.home-btn, .cart-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  margin: 0 20rpx;
  color: var(--color-text-secondary);
}

.home-btn icon, .cart-btn icon {
  font-size: 40rpx;
}

.add-cart, .buy-now {
  flex: 1;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 35rpx;
  font-size: 26rpx;
  margin-left: 10rpx;
  font-weight: 500;
  color: #fff;
}

/* Add to Cart - Accent Coral */
.add-cart {
  background-color: var(--color-accent);
}

/* Buy Now - Primary Navy */
.buy-now {
  background-color: var(--color-primary);
}

/* ============================================
   Recommendations Section
   ============================================ */
.recommendations {
  padding: 30rpx;
  margin-top: 20rpx;
  background-color: var(--color-surface);
  border-radius: 12rpx;
  margin: 20rpx;
  border: 1rpx solid var(--color-border);
}

.recommend-group {
  margin-bottom: 30rpx;
}

.recommend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.recommend-title {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 600;
}

.recommend-scroll {
  white-space: nowrap;
  width: 100%;
}

.recommend-list {
  display: flex;
  flex-direction: row;
}

.recommend-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
  width: 200rpx;
}

.recommend-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background-color: var(--color-bg-subtle);
}

.recommend-name {
  font-size: 24rpx;
  color: var(--color-text);
  margin-top: 10rpx;
  width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommend-price {
  font-size: 24rpx;
  color: var(--color-price);
  margin-top: 5rpx;
  font-weight: 600;
}

.loading-recommendations {
  text-align: center;
  padding: 30rpx;
  color: var(--color-text-muted);
  font-size: 26rpx;
}

.card {
  background-color: var(--color-surface);
  margin: 20rpx;
  border-radius: 12rpx;
  padding: 20rpx;
  border: 1rpx solid var(--color-border);
}

.section {
  margin-top: 0;
}
