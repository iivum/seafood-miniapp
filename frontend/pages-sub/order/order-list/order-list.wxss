.order-list-container {
  padding: 20rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  color: var(--color-text-muted);
}

.order-card {
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.order-id {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.order-status {
  font-size: 24rpx;
  font-weight: bold;
}

.status-PENDING_PAYMENT { color: #ff9500; }
.status-PAID { color: var(--color-primary); }
.status-SHIPPED { color: var(--color-success); }
.status-COMPLETED { color: var(--color-text-muted); }
.status-CANCELLED { color: var(--color-price); }

.order-items {
  padding: 20rpx 0;
}

.item {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.item-name {
  flex: 1;
}

.item-qty {
  width: 80rpx;
  text-align: center;
  color: var(--color-text-muted);
}

.item-price {
  width: 150rpx;
  text-align: right;
  font-weight: bold;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-divider);
}

.total {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-price);
}

.actions {
  display: flex;
}

.btn {
  font-size: 24rpx;
  margin-left: 20rpx;
  padding: 0 30rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 30rpx;
}

.btn-pay {
  background-color: var(--color-primary);
  color: #fff;
}

.btn-cancel {
  background-color: var(--color-bg-subtle);
  color: var(--color-text-secondary);
}
