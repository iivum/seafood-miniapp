.order-confirm-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: calc(140rpx + var(--safe-area-bottom));
}

.section {
  background-color: var(--color-surface);
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 600;
}

/* Address Section */
.address-section {
  display: flex;
  flex-direction: column;
}

.address-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.address-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.address-info > *:not(:first-child) {
  margin-top: 10rpx;
}

.receiver {
  font-size: 30rpx;
  color: var(--color-text);
  font-weight: 500;
}

.detail {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.address-placeholder {
  flex: 1;
  color: var(--color-text-muted);
  font-size: 28rpx;
}

.arrow {
  font-size: 36rpx;
  color: var(--color-text-muted);
  padding-left: 20rpx;
}

/* Items Section */
.items-list {
  display: flex;
  flex-direction: column;
}

.items-list > *:not(:first-child) {
  margin-top: 20rpx;
}

.item {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background-color: var(--color-bg-subtle);
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.item-info > *:not(:first-child) {
  margin-top: 8rpx;
}

.item-name {
  font-size: 28rpx;
  color: var(--color-text);
}

.item-price {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.item-qty {
  font-size: 26rpx;
  color: var(--color-text-muted);
  padding-left: 20rpx;
}

/* Summary Section */
.summary-section {
  display: flex;
  flex-direction: column;
}

.summary-section > *:not(:first-child) {
  margin-top: 20rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.value {
  font-size: 28rpx;
  color: var(--color-text);
}

.free-shipping {
  color: var(--color-success);
}

.total-row {
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-bg-subtle);
}

.total-price {
  font-size: 32rpx;
  color: var(--color-price);
  font-weight: 600;
}

/* Bottom Bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: var(--fixed-bar-height);
  background-color: var(--color-surface);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  padding-bottom: var(--safe-area-bottom);
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.total-info {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.total-amount {
  font-size: 36rpx;
  color: var(--color-price);
  font-weight: 600;
}

.btn-submit {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: var(--color-success);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

.btn-submit[disabled] {
  background-color: var(--color-text-muted);
}
